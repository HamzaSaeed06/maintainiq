# Node dependencies
node_modules/
**/node_modules/

# Secrets and local configurations (do not commit actual env configuration files)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local
**/.env.*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dev and Build Outputs
dist/
dist-ssr/
build/
.vite/
.output/
.nuxt/
.next/

# IDEs / Editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS metadata
.DS_Store
Thumbs.db

# Docker volumes and database data dump folders
docker-data/
pg-data/
db-data/
mongo-data/

# Testing
coverage/
.nyc_output/

# Uploads directory contents (ignore uploaded images/files, but track the folder)
backend/uploads/*
!backend/uploads/.gitkeep

# Documentation (internal docs only - keep API_DOCS.md and README.md)
docs/
docs/**

# Test scripts (development only)
backend/scripts/test*.js

# AI Agent workflows (not part of the application)
_agent/

# Debug and test files
*.json.bak
gemini_out.json
workflows.log

# Empty directories (will be recreated if needed)
frontend/src/assets/
frontend/src/utils/